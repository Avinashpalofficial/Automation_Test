{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "types": ["node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],

    "skipLibCheck": true
  },

  "include": ["src"]
}
